{
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/favicon.ico",
      "dest": "/icons/icon.svg"
    },
    {
      "src": "/favicon.png",
      "dest": "/icons/icon.svg"
    },
    {
      "src": "/admin",
      "dest": "/index.html"
    },
    {
      "src": "/[^/.]+",
      "dest": "/index.html"
    }
  ]
}
